# API URLs for 3 Independent Microservices
# Copy this file to .env and update the URLs

# Development (localhost)
VITE_CRUD_API_URL=http://localhost:3001/api/v1
VITE_BUSINESS_API_URL=http://localhost:3002/api/v1
VITE_EXTERNAL_API_URL=http://localhost:3003/api/v1

