# Medical Appointment System - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# DATABASE (Supabase)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# API PORTS (Microservices)
# =============================================================================
# Each API runs on its own port for independence
CRUD_API_PORT=3001
BUSINESS_API_PORT=3002
EXTERNAL_API_PORT=3003

# Legacy single server port (for backward compatibility)
PORT=3000

# =============================================================================
# EMAIL SERVICE (SendGrid)
# =============================================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Medical Appointment System

# =============================================================================
# FRONTEND URLS (for CORS and email links)
# =============================================================================
FRONTEND_URL=http://localhost:5500
FRONTEND_URL_PROD=https://your-frontend.vercel.app

# =============================================================================
# QR CODE SETTINGS
# =============================================================================
QR_VERIFICATION_URL=https://your-domain.com/verify

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development
